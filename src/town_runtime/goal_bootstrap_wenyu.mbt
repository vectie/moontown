///|
async fn preseed_wenyu_source_bundle(root : String, repo_root : String) -> Unit {
  let bundle_root = "\{root}/mounted-sources"
  @support.write_text_file(
    "\{bundle_root}/MANIFEST.md",
    [
      "# Mounted Source Manifest", "", "This bundle is generated by Moontown when bootstrapping a Wenyu Valley lane.",
      "It gives isolated MoonBook/MoonClaw workers local, readable evidence without granting town-global filesystem authority.",
      "", "## Moontown", "", "- `moontown/ui-rabbita-town-main.mbt` from `src/ui/rabbita-town/main/main.mbt`",
      "- `moontown/ui-rabbita-town-styles.css` from `src/ui/rabbita-town/styles.css`",
      "- `moontown/roles-mayor.mbt` from `src/roles/mayor.mbt`", "- `moontown/goal-run.mbt` from `src/town_runtime/goal_run.mbt`",
      "- `moontown/goal-bootstrap.mbt` from `src/town_runtime/goal_bootstrap.mbt`",
      "- `moontown/scheduler-daemon.mbt` from `src/scheduler/daemon.mbt`", "- `moontown/moontown.mbt` from `src/town_runtime/moontown.mbt`",
      "- `moontown/adapters-moonbook-client.mbt` from `src/adapters/moonbook/client.mbt`",
      "- `moontown/adapters-moonclaw-import.mbt` from `src/adapters/moonclaw/import.mbt`",
      "", "## MoonBook", "", "- `moonbook/research-report-skill.md` from `../moonbook/seed/wiki/skills/research-report/SKILL.md`",
      "- `moonbook/wiki-ingest-skill.md` from `../moonbook/seed/wiki/skills/wiki-ingest/SKILL.md`",
      "- `moonbook/wiki-marketing-skill.md` from `../moonbook/seed/wiki/skills/wiki-marketing/SKILL.md`",
      "- `moonbook/wiki-ui-state-content.mbt` from `../moonbook/wiki/ui_state_content.mbt`",
      "- `moonbook/wiki-extensions-profiles.mbt` from `../moonbook/wiki/extensions_profiles.mbt`",
      "", "## MoonClaw", "", "- `moonclaw/provider-task-execution-skill.md` from `../moonclaw/skills/provider-task-execution/SKILL.md`",
      "- `moonclaw/research-report-writer-skill.md` from `../moonclaw/skills/research-report-writer/SKILL.md`",
      "- `moonclaw/job-provider-task.mbt` from `../moonclaw/job/provider_task.mbt`",
      "- `moonclaw/job-analysis-runner.mbt` from `../moonclaw/job/analysis_runner.mbt`",
      "", "## Research Rule", "", "Use these snapshots after web discovery to verify implementation readiness, ownership boundaries, and projection/runtime gaps.",
      "",
    ].join("\n"),
  )
  copy_source_snapshot(
    source="\{repo_root}/src/ui/rabbita-town/main/main.mbt",
    dest="\{bundle_root}/moontown/ui-rabbita-town-main.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/ui/rabbita-town/styles.css",
    dest="\{bundle_root}/moontown/ui-rabbita-town-styles.css",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/roles/mayor.mbt",
    dest="\{bundle_root}/moontown/roles-mayor.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/town_runtime/goal_run.mbt",
    dest="\{bundle_root}/moontown/goal-run.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/town_runtime/goal_bootstrap.mbt",
    dest="\{bundle_root}/moontown/goal-bootstrap.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/scheduler/daemon.mbt",
    dest="\{bundle_root}/moontown/scheduler-daemon.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/town_runtime/moontown.mbt",
    dest="\{bundle_root}/moontown/moontown.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/adapters/moonbook/client.mbt",
    dest="\{bundle_root}/moontown/adapters-moonbook-client.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/src/adapters/moonclaw/import.mbt",
    dest="\{bundle_root}/moontown/adapters-moonclaw-import.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonbook/seed/wiki/skills/research-report/SKILL.md",
    dest="\{bundle_root}/moonbook/research-report-skill.md",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonbook/seed/wiki/skills/wiki-ingest/SKILL.md",
    dest="\{bundle_root}/moonbook/wiki-ingest-skill.md",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonbook/seed/wiki/skills/wiki-marketing/SKILL.md",
    dest="\{bundle_root}/moonbook/wiki-marketing-skill.md",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonbook/wiki/ui_state_content.mbt",
    dest="\{bundle_root}/moonbook/wiki-ui-state-content.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonbook/wiki/extensions_profiles.mbt",
    dest="\{bundle_root}/moonbook/wiki-extensions-profiles.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonclaw/skills/provider-task-execution/SKILL.md",
    dest="\{bundle_root}/moonclaw/provider-task-execution-skill.md",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonclaw/skills/research-report-writer/SKILL.md",
    dest="\{bundle_root}/moonclaw/research-report-writer-skill.md",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonclaw/job/provider_task.mbt",
    dest="\{bundle_root}/moonclaw/job-provider-task.mbt",
  )
  copy_source_snapshot(
    source="\{repo_root}/../moonclaw/job/analysis_runner.mbt",
    dest="\{bundle_root}/moonclaw/job-analysis-runner.mbt",
  )
}

///|
async fn copy_source_snapshot(source~ : String, dest~ : String) -> Unit {
  match @support.read_optional_text(source) {
    Some(text) =>
      @support.write_text_file(
        dest,
        ["---", "source: \{source}", "generated_by: moontown", "---", "", text].join(
          "\n",
        ),
      )
    None => ()
  }
}

///|
fn moontown_repo_root() -> String {
  match @env.current_dir() {
    Some(dir) => dir
    None => "."
  }
}

///|
fn wenyu_module_name(entry : @moonbook.BookCatalogEntry) -> String {
  let prefix = "Wenyu Valley / "
  if entry.name.has_prefix(prefix) {
    entry.name.replace(old=prefix, new="")
  } else {
    entry.name
  }
}

///|
fn is_wenyu_book(entry : @moonbook.BookCatalogEntry) -> Bool {
  entry.id.has_prefix("wenyu-")
}

///|
async fn wenyu_book_ready_for_build(entry : @moonbook.BookCatalogEntry) -> Bool {
  if !is_wenyu_book(entry) {
    return false
  }
  let root = @moonbook.workspace_root(entry)
  let required = [
    "raw/bootstrap/deep-report.md", "raw/bootstrap/evidence-matrix.md", "raw/bootstrap/marketing-brief.md",
    "raw/bootstrap/local-sources.md", "mounted-sources/MANIFEST.md",
  ]
  @support.workspace_relative_paths_ready(root, required)
}

///|
fn wenyu_build_task_limit(task_limit : Int) -> Int {
  if task_limit < 4 {
    4
  } else {
    task_limit
  }
}

///|
fn wenyu_build_plan(
  entry : @moonbook.BookCatalogEntry,
  objective : String,
  task_limit : Int,
) -> ResearchBootstrapPlan {
  {
    tasks: wenyu_build_tasks(entry, objective),
    task_limit: wenyu_build_task_limit(task_limit),
    bootstrap_active: false,
  }
}

///|
fn wenyu_build_tasks(
  entry : @moonbook.BookCatalogEntry,
  objective : String,
) -> Array[@moonbook.BookTask] {
  let module_name = wenyu_module_name(entry)
  let repo_root = moontown_repo_root()
  let build_tasks = [
    @moonbook.BookTask::new(
      id="goal-\{entry.id}-implementation-backlog",
      goal=Some(objective),
      title="Compile implementation backlog for \{module_name}",
      kind="implementation-backlog",
      prompt=@build_pipeline.wenyu_implementation_backlog_prompt(
        entry, objective, repo_root,
      ),
      priority=120,
      requires_review=true,
      target_pages=[
        "build/IMPLEMENTATION_BACKLOG.md",
        "build/ACCEPTANCE_TESTS.md",
        "wiki/synthesis/\{entry.id}-build-plan.md",
      ],
      required_role=Some(@core.WorkerRole::Planner),
    ),
    @moonbook.BookTask::new(
      id="goal-\{entry.id}-code-patch",
      goal=Some(objective),
      title="Implement code slice for \{module_name}",
      kind="code-patch",
      prompt=@build_pipeline.wenyu_code_patch_prompt(
        entry, objective, repo_root,
      ),
      priority=115,
      requires_review=true,
      target_pages=[
        "build/CODE_PATCH.md", "build/TEST_RESULTS.md", "repo:/Users/kq/Workspace/moontown",
      ],
      required_role=Some(@core.WorkerRole::Harness),
    ),
    @moonbook.BookTask::new(
      id="goal-\{entry.id}-asset-pack",
      goal=Some(objective),
      title="Generate asset and projection pack for \{module_name}",
      kind="image-asset",
      prompt=@build_pipeline.wenyu_asset_pack_prompt(
        entry, objective, repo_root,
      ),
      priority=110,
      requires_review=true,
      target_pages=[
        "build/ASSET_PROMPTS.md",
        "build/ASSET_MANIFEST.md",
        @policy.default_generated_site_projection_path(),
      ],
      required_role=Some(@core.WorkerRole::Specialist),
    ),
  ]
  match @civic.wenyu_civic_service_for_book_id(entry.id) {
    Some(service) =>
      [@civic.wenyu_civic_service_task(service, objective), ..build_tasks]
    None => build_tasks
  }
}

///|
fn wenyu_civic_service_plan(
  entry : @moonbook.BookCatalogEntry,
  objective : String,
  tasks : Array[@moonbook.BookTask],
  task_limit : Int,
) -> ResearchBootstrapPlan {
  match @civic.wenyu_civic_service_for_book_id(entry.id) {
    Some(service) => {
      let service_task = @civic.wenyu_civic_service_task(service, objective)
      let ordered = prioritized_tasks(tasks, objective)
      let merged = [service_task]
      for task in ordered {
        if task.id != service_task.id &&
          task.kind != "research-bootstrap-ingest" {
          merged.push(task)
        }
      }
      {
        tasks: merged,
        task_limit: if task_limit < 1 {
          1
        } else {
          task_limit
        },
        bootstrap_active: false,
      }
    }
    None =>
      {
        tasks: prioritized_tasks(tasks, objective),
        task_limit: if task_limit < 1 {
          1
        } else {
          task_limit
        },
        bootstrap_active: false,
      }
  }
}
