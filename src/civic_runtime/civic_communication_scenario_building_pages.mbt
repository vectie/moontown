///|
fn civic_salon_building_synthesis(
  scenario : CivicCommunicationScenario,
  protocol : @civic.BuildingProtocolDefinition,
  participants : Array[CivicCommunicationParticipantBook],
  ideas : Array[CivicCommunicationIdea],
  metrics : CivicCommunicationMetric,
  round_id : String,
  round_number : Int,
) -> String {
  let pattern = @civic.communication_pattern_for_scenario(scenario)
  [
    "# \{scenario.title}",
    "",
    civic_salon_round_metadata(round_id, round_number),
    "",
    @civic.communication_building_intro(pattern, protocol),
    "",
    "## Participants",
    "",
    civic_salon_participant_table(participants),
    "",
    "## Reduced Pattern Outputs",
    "",
    civic_salon_idea_sections(ideas),
    "",
    "## Effectiveness Metrics",
    "",
    civic_salon_metrics_table(metrics),
    "",
    @civic.salon_structural_metric_note(),
    "",
    "## Quality Standard",
    "",
    @support.markdown_bullets(scenario.quality_rules),
  ].join("\n")
}

///|
fn civic_salon_round_metadata(round_id : String, round_number : Int) -> String {
  ["- Round: `\{round_id}`", "- Round number: `\{round_number}`"].join("\n")
}

///|
fn civic_salon_idea_backlog(
  scenario : CivicCommunicationScenario,
  ideas : Array[CivicCommunicationIdea],
) -> String {
  [
    "# \{scenario.title} Follow-up Backlog",
    "",
    "Reviewable outputs and follow-up questions generated by \{scenario.title}.",
    "",
    civic_salon_idea_sections(ideas),
  ].join("\n")
}

///|
fn civic_salon_review_queue(
  scenario : CivicCommunicationScenario,
  ideas : Array[CivicCommunicationIdea],
) -> String {
  let builder = StringBuilder::new()
  builder.write_string("# \{scenario.title} Review\n\n")
  builder.write_string("| ID | Idea | Review Need | Status |\n")
  builder.write_string("| --- | --- | --- | --- |\n")
  for idea in ideas {
    builder.write_string(
      "|\{idea.id}|\{idea.title}|\{scenario.review_reason}|pending|\n",
    )
  }
  builder.to_string()
}
