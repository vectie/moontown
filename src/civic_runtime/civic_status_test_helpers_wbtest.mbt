///|
fn test_civic_service_health(
  title? : String = "Policy Hall",
  status? : String = "seeded",
  protocol_status? : String = "defined",
  operable? : Bool = true,
  latest_decision? : String = "none",
  latest_pages_changed? : Int = 0,
  latest_accepted_facts? : Int = 0,
  latest_review_items? : Int = 0,
  protocol_inbox_count? : Int = 0,
  protocol_contribution_count? : Int = 0,
  protocol_reduction_count? : Int = 0,
  protocol_outbox_count? : Int = 0,
  protocol_review_count? : Int = latest_review_items,
  latest_protocol_summary? : String = "",
  missing_required_paths? : Array[String] = [],
  notes? : Array[String] = ["workspace is operable"],
) -> CivicServiceHealth {
  {
    service_id: "policy-hall",
    title,
    book_id: "wenyu-policy-hall",
    service_kind: "policy-service",
    module_mode: "agent-workspace",
    book_role: "source-backed-service-workspace",
    skill_mode: "policy-intelligence",
    protocol_status,
    protocol_ready: protocol_status != "defined",
    protocol_inbox_count,
    protocol_contribution_count,
    protocol_reduction_count,
    protocol_outbox_count,
    protocol_review_count,
    latest_protocol_summary,
    protocol_history: [],
    protocol_history_state: "no-events-yet",
    workspace_root: "/tmp/policy",
    status,
    operable,
    proven_by_result: latest_decision != "none",
    workspace_exists: true,
    schema_ready: true,
    wiki_ready: true,
    review_ready: true,
    projection_ready: true,
    skill_ready: true,
    moonclaw_profile_ready: true,
    latest_result_path: ".moontown/book-results/goal-wenyu-policy-hall-civic-service.json",
    latest_result_found: latest_decision != "none",
    latest_decision,
    latest_book_changed: "unknown",
    latest_pages_changed,
    latest_accepted_facts,
    latest_review_items,
    next_check_hint: "unknown",
    missing_required_paths,
    notes,
  }
}
