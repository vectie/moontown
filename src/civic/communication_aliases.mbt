///|
/// Generic civic communication vocabulary.
///
/// `research-salon` remains one pattern kind, but the runtime envelope is a
/// reusable communication protocol. These aliases give new code the generic
/// names while older scenario templates and call sites migrate away from the
/// historical salon vocabulary.
pub type CivicCommunicationReductionMode = CivicSalonReductionMode

///|
pub type CivicCommunicationParticipantBook = CivicSalonParticipantBook

///|
pub type CivicCommunicationIdea = CivicSalonIdea

///|
pub type CivicCommunicationMetric = CivicSalonMetric

///|
pub type CivicCommunicationMetricCounts = CivicSalonMetricCounts

///|
pub type CivicCommunicationHomeReturn = CivicSalonHomeReturn

///|
pub type CivicCommunicationScenario = CivicSalonScenario

///|
pub type CivicCommunicationSchedule = CivicSalonSchedule

///|
pub type CivicCommunicationRoundRecord = CivicSalonRoundRecord
