{
  "id": "wenyu-valley-isometric",
  "orientation": "isometric",
  "sourceTileWidth": 128,
  "sourceTileHeight": 96,
  "renderTileWidth": 44,
  "renderTileHeight": 33,
  "gridStepX": 18,
  "gridStepY": 9,
  "viewportGridWidth": 256,
  "viewportGridHeight": 144,
  "viewportPolicy": "Render a draggable Wenyu Valley masterplan tilemap: right-side river corridor, central wetlands, diagonal road grids, dense urban clusters, satellite campuses, farmland blocks, forest buffers, ponds, bridges, and edge haze matching the reference aerial composition.",
  "assetPolicy": "Keep semantic labels in JSON, generate transparent PNG tiles/sprites from the approved visual references, then bake the standalone viewport into a raster layer for smooth drag and zoom.",
  "semanticLayers": {
    "terrain": {
      "path": "wenyu_reference_labels.json",
      "gridWidth": 256,
      "gridHeight": 144
    },
    "buildings": {
      "path": "wenyu_reference_buildings.json",
      "source": "wenyu_reference_buildings_source.png",
      "preview": "wenyu_reference_buildings_preview.png",
      "method": "Shape-first extraction from reference.png: label exact footprint cells, preserve road/grid seams, classify connected components, and bake those outlines into the viewport raster."
    },
    "standaloneRaster": {
      "path": "wenyu_reference_tilemap_iso.png",
      "source": "terrain + buildings",
      "reason": "A single raster layer avoids moving tens of thousands of DOM nodes while dragging or zooming."
    }
  },
  "tiles": {
