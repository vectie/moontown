///|
pub fn code_plan_skill_markdown() -> String {
  [
    "---",
    "name: code-plan",
    "description: Produce implementation-grade plans for code, product, UI, daemon, documentation, or multi-agent changes.",
    "---",
    "",
    "# Code Plan Skill",
    "",
    "Create a durable plan that a fresh MoonClaw or Codex session can execute without hidden chat context.",
    "",
    "## Required Shape",
    "",
    "- Problem",
    "- Current state with file/doc references",
    "- Goal and non-goals",
    "- Operating architecture fit",
    "- Design decision",
    "- Alternatives considered",
    "- Affected files and packages",
    "- Implementation steps",
    "- Acceptance criteria with checkboxes",
    "- Validation commands",
    "- Growth and monitoring evidence",
    "- Rollback/recovery path",
    "- Follow-up tasks",
    "",
    "## Architecture Rules",
    "",
    "- State which durable document/book/ledger owns the truth.",
    "- State whether the active protocol is Mayor supervision, MoonBook bookkeeper work, MoonClaw worker execution, civic building exchange, or Moondesk human workspace.",
    "- Treat civic buildings as protocol places, not generic agent containers.",
    "- Treat MoonClaw workers as freelance bounded executors, not durable memory owners.",
    "- Treat MoonBook bookkeepers as resident roles that wake on schedules/events and decide memory promotion, review, and projection quality.",
    "- Include how accepted output returns home to the owning book or review queue.",
    "",
    "## Quality Bar",
    "",
    "- Be specific to this repo and this runtime.",
    "- Avoid generic advice.",
    "- Explain ownership boundaries.",
    "- Make the plan small enough to execute, but complete enough to resume.",
    "- Say what should grow over time: book pages, protocol ledgers, PlanBook evidence, code/tests, UI projections, or explicit no-change records.",
    "",
    @skill_quality.exploration_quality_contract_section(),
    "",
    "## Concrete Example",
    "",
    "```md",
    "# Plan: Add Book Quality Audit",
    "Problem: registered books can drift without a durable score.",
    "Operating architecture fit: PlanBook owns the change plan; Moontown runs the audit; MoonClaw may review; MoonBook stores review evidence.",
    "Affected files: `book_quality.mbt`, `cmd/main/main.mbt`, `docs/USAGE.md`.",
    "Acceptance: `books doctor` writes JSON/Markdown; weak books are listed first; `moon check` passes.",
    "```",
  ].join("\n")
}

///|
pub fn code_review_skill_markdown() -> String {
  [
    "---",
    "name: code-review",
    "description: Review a completed plan for regressions, missing validation, boundary leaks, and unresolved acceptance criteria.",
    "---",
    "",
    "# Code Review Skill",
    "",
    "Review the plan outcome before it is promoted into stable state.",
    "",
    "## Checklist",
    "",
    "- Did the implementation satisfy each acceptance criterion?",
    "- Were tests run and recorded?",
    "- Did public APIs change intentionally?",
    "- Did any book type inherit the wrong skill/profile/projection?",
    "- Did operational evidence inflate domain evidence?",
    "- Is cookbook impact explicit?",
    "",
    @skill_quality.exploration_quality_contract_section(),
    "",
    "## Concrete Example",
    "",
    "```md",
    "review_decision: needs_fix",
    "finding: course book still uses research index metadata.",
    "fix_owner: MoonBook projection layer",
    "validation_needed: rerun course bootstrap and inspect `wiki/index.md`.",
    "```",
  ].join("\n")
}

///|
pub fn doc_sync_skill_markdown() -> String {
  [
    "---",
    "name: doc-sync",
    "description: Synchronize accepted implementation changes into Moontown docs and cookbook stable-state definitions.",
    "---",
    "",
    "# Doc Sync Skill",
    "",
    "Update documentation only after the plan evidence proves the behavior changed.",
    "",
    "## Rules",
    "",
    "- Update operator commands, architecture ownership, and known limitations.",
    "- Link from cookbook when the stable state changes.",
    "- Do not document aspirational behavior as already working.",
    "",
    @skill_quality.exploration_quality_contract_section(),
    "",
    "## Concrete Example",
    "",
    "```md",
    "doc_sync_decision: update",
    "docs_changed: `docs/USAGE.md`, `docs/ARCHITECTURE.md`",
    "cookbook_changed: yes",
    "reason: new `books doctor` command is now validated.",
    "```",
  ].join("\n")
}
